{
  "$schema": "http://json.schemastore.org/electron-builder",
  "appId": "com.deepbluedynamics.meridian",
  "productName": "Meridian",
  "artifactName": "${productName}-${version}-${arch}.${ext}",
  "afterPack": "./build/hooks/copy-radio.cjs",
  "files": [
    "electron/**/*",
    "lib/**/*",
    "*.html",
    "!**/*.log",
    "!**/*.map"
  ],
  "extraResources": [
    {
      "from": "./sidecar/target/release/meridian-sidecar.exe",
      "to": "./sidecar/meridian-sidecar.exe"
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "zip", "arch": ["x64"] }
    ]
  },
  "nsis": {
    "shortcutName": "Meridian",
    "uninstallDisplayName": "Meridian",
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  },
  "publish": null
}
