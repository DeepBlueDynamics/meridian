# Meridian — copy to `.env` and fill in. `.env` is gitignored; never commit a real key.

# Google Photorealistic 3D Tiles — read by the Electron MAIN process only
# (electron/main.js). Never exposed to the renderer; the proxy signs requests.
#
# Setup:
#   1. https://console.cloud.google.com  → create/select a project
#   2. APIs & Services → Library → enable "Map Tiles API"
#   3. Enable BILLING on the project (required even for the free tier)
#   4. Credentials → create an API key
#   5. Restrict it: Application restrictions = IP addresses (server outbound IPs,
#      NOT HTTP referrer); API restrictions = Map Tiles API only
#   6. Quotas → Map Tiles API → set a daily root-tile cap (start 500/day)
#   7. Budget alert at $25/month
GOOGLE_MAPS_API_KEY=

# Routing data (Open-Meteo ensemble wind + Copernicus marine currents) and the
# Nominatim/Overpass lookups need NO key.

# Helm terminal widget builder (LLM relay — main process only)
ANTHROPIC_API_KEY=
